# ============================================================
# Veeam-HealthCheck-Simplifier — .gitignore
# Generated: 2026-06-20
# ============================================================

# ------------------------------------------------------------
# VHC runtime output artifacts
# Generated by vhc_simplifier.py at runtime — never source.
# ------------------------------------------------------------

# Markdown remediation summary (--output-dir default)
remediation_summary.md
*_remediation_summary.md
vhc_summary*.md

# PowerShell remediation script output
fixit.ps1
*_fixit.ps1
remediation*.ps1

# Ticket/integration export (Salesforce, JSON output)
tickets.json
*_tickets.json
vhc_tickets*.json

# Raw VHC input files (customer data — never commit)
*.vhc
vhc_input*.csv
vhc_input*.json
healthcheck*.csv
healthcheck*.json

# Any output directory if --output-dir is used
output/
vhc_output/

# docker-compose.yml default bind-mount targets — may contain real customer
# VHC export data or generated artifacts; never commit either.
/output/
/vhc-exports/

# ------------------------------------------------------------
# Secrets / environment
# (vhc_simplifier enforces env-var creds — keep them out)
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.env
secrets.json
sf_config.json

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
nosetests.xml
pytest.ini.bak

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
# Editor / OS
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
